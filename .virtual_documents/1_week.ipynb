def merge_dicts(a: dict, b: dict) -> dict:
    a1, b1 = a, b
    a1.update(b1)
    return a1

dict1 = {
    "name": "Alice",
    "age": 25,
    "city": "Berlin",
    "job": "Engineer"
}

dict2 = {
    "name": "Bob",
    "age": 30,
    "city": "Paris",
    "salary": 5000
}


print(merge_dicts(dict1, dict2))


#18.
def invert_dict(d: dict):
    new_dict = {}
    for k_v in d.items():
        new_dict[k_v[1]] = k_v[0]
    return new_dict

data = {
    "user1": "admin",
    "user2": "editor",
    "user3": "admin",
    "user4": "viewer",
    "user5": "editor",
    "user6": "admin"
}

print(invert_dict(data))


