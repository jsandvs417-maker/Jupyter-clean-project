def flatten(list_of_lists: list):
    res = []
    for elem in list_of_lists:
        res.extend(elem)
    return res
data = [
    [3, 7, 12],
    [5, 9],
    [14, 2, 8, 11],
    [6],
    [10, 4, 1]
]

print(flatten(data))


