#8.
def counter(start=0, step=1):
    count = 0
    def next_value():
        nonlocal count
        count += 1
        return start + count * step
    return next_value


value_plus = counter()

print(value_plus())
print(value_plus())
print(value_plus())


#9.
def unique(seq):
    md = {}
    for e in seq:
        md[e] = md.get(e, 0) + 1
    return list(md.keys())


ml = [42, 'apple', 3.14, 'apple', True, (1, 2), 42, False, (1, 2), 'banana']
print(unique(ml))


#10.
def fib(n, memo_d = {0: 0, 1: 1}):
    if n in memo_d:
        return memo_d[n]
    else:
        memo_d[n] = fib(n-1) + fib(n-2)
        return memo_d[n]

print(fib(7))


