#20.
import functools
def retry(callable_obj, attempts=3):
    @functools.wraps
    def wrapper(*args, **kwargs):
        try:
            value = callable_obj(*args, **kwargs)
            return value
        except:
            while True:
                if attempts != 0:
                    value = callable_obj(*args, **kwargs)
                    attempts -= 1
                return None
    return wrapper
